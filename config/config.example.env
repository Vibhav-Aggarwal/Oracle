# Oracle Bot V2 - Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# TRADING MODE
# =============================================================================
TRADING_MODE=PAPER                    # PAPER or LIVE

# =============================================================================
# DELTA EXCHANGE (Derivatives)
# =============================================================================
DELTA_API_KEY=your_delta_api_key
DELTA_API_SECRET=your_delta_api_secret
DELTA_TESTNET=false                   # true for testnet

# =============================================================================
# ZEBPAY (Spot - India)
# =============================================================================
ZEBPAY_API_KEY=your_zebpay_api_key
ZEBPAY_API_SECRET=your_zebpay_api_secret

# =============================================================================
# COINBASE (Spot - International)
# =============================================================================
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret
COINBASE_PASSPHRASE=your_coinbase_passphrase

# =============================================================================
# RISK MANAGEMENT
# =============================================================================
MAX_POSITIONS=5                       # Maximum concurrent positions
BASE_POSITION_SIZE_PCT=0.02           # Risk per trade (2%)
LEVERAGE=20                           # Default leverage
MIN_SCORE_THRESHOLD=40                # Minimum signal score

# =============================================================================
# STOP LOSS / TAKE PROFIT
# =============================================================================
ATR_SL_MULTIPLIER=2.0                 # Stop loss at 2x ATR
ATR_TP_MULTIPLIER=3.0                 # Take profit at 3x ATR
IMMEDIATE_LOSS_EXIT=-3.0              # Emergency exit at -3%

# =============================================================================
# TRAILING STOP
# =============================================================================
TRAIL_START_PCT=3.0                   # Start trailing at +3%
MIN_TRAIL_DIST=1.0                    # Minimum trail distance 1%
MAX_TRAIL_DIST=3.0                    # Maximum trail distance 3%

# =============================================================================
# COOLDOWNS & LIMITS
# =============================================================================
COIN_BLACKLIST_TIME=3600              # 1 hour cooldown after exit
COOLDOWN_AFTER_EXIT=30                # Seconds before re-entry
MAX_CONSECUTIVE_LOSSES=3              # Pause after N losses
DAILY_DRAWDOWN_LIMIT=10.0             # Max daily loss %

# =============================================================================
# TELEGRAM ALERTS (Optional)
# =============================================================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# =============================================================================
# AI SERVERS (Optional - For Sentiment Analysis)
# =============================================================================
PPO_SERVER=http://localhost:5002
FINBERT_SERVER=http://localhost:5001

# =============================================================================
# PATHS
# =============================================================================
STATE_FILE=/home/user/oracle_state.json
LOG_FILE=/tmp/oracle_bot.log

# =============================================================================
# DASHBOARD
# =============================================================================
DASHBOARD_PORT=5000
WEBHOOK_PORT=8080
